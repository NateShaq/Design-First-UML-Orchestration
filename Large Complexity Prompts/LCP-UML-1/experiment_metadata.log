    {
        var fact = await _context.SignalEventFacts.AsNoTracking()
            .Include(f => f.SignalController)
            .Include(f => f.Calendar)
            .FirstOrDefaultAsync(f => f.EventId == id, cancellationToken);
        return fact is null ? NotFound() : fact;
    }

