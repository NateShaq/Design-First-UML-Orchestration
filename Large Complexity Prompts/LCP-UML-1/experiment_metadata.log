'================ Platform Services (ACID & Concurrency) ================
package \"Platform\" {
  interface VersionedResource {
    +version: long
    +lastWriteAt: DateTime
    +acquireLock()
    +commitWithCAS()
  }
  class GhostWriteGuard {
    +validate(version)
    +rejectOnStaleWrite()
  }
  class TransactionManager {
    +begin()
    +commit()
    +rollback()
  }
  class UnitOfWork {
    +aggregateChanges()
    +flush()
  }
  class WriteAheadLog {
    +append(entry)
    +fsync()
  }
  class OutboxRelay {
    +publish(domainEvent)
  }
  class ACIDWorkflow {
    +isolationLevel: IsolationLevel
    +durability: WAL+fsync
  }
}

