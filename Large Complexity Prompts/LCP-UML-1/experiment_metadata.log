+        modelBuilder.Entity<MaintenanceFact>()
+            .HasOne(f => f.Schedule)
+            .WithMany(s => s.MaintenanceFacts)
+            .HasForeignKey(f => f.ScheduleId)
+            .OnDelete(DeleteBehavior.Restrict);
+
+        modelBuilder.Entity<MaintenanceFact>()
+            .HasOne(f => f.Calendar)
+            .WithMany()
+            .HasForeignKey(f => f.DateId)
+            .OnDelete(DeleteBehavior.Restrict);
+
+        base.OnModelCreating(modelBuilder);
+    }
+}
