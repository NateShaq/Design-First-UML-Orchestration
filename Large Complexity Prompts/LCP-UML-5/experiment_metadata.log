diff --git a/Large Complexity Prompts/LCP-UML-5/src/LcpUml5.Api/Infrastructure/BankingDbContext.cs b/Large Complexity Prompts/LCP-UML-5/src/LcpUml5.Api/Infrastructure/BankingDbContext.cs
