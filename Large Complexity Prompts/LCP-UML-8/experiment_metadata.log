+    public ICollection<TraceabilityRecord> TraceabilityRecords { get; set; } = new List<TraceabilityRecord>();
+}
+
+public class NonConformance
+{
+    [Key]
+    [MaxLength(64)]
+    public string Id { get; set; } = Guid.NewGuid().ToString("N");
+
+    [Required, MaxLength(50)]
