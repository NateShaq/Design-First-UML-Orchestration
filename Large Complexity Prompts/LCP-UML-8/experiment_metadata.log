+    public string Id { get; set; } = Guid.NewGuid().ToString("N");
+
+    [Required, MaxLength(50)]
+    public string Status { get; set; } = "Pending";
+
+    [Required]
+    public string InspectionPlanId { get; set; } = string.Empty;
