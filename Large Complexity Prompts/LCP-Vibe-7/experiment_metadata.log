+            new ResearchFellow { Id = 3, StudentNumber = "R0001", FullName = "Noah South", Email = "noah.south@example.edu", AcademicProgramId = 2, ResearchArea = "Learning Analytics", SupervisorFacultyId = 2 }
+        });
